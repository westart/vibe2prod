# vibe2prod configuration. Copy to .env and adjust — or don't: every value
# here works out of the box. Values must not contain spaces or quotes.

# ── Domain & TLS ─────────────────────────────────────────────────────────────
# Your domain, with an A record pointing at the server (you can create the
# record AFTER deploy; Let's Encrypt retries automatically).
# Leave as "auto" to get a free HTTPS URL via sslip.io based on the server IP —
# no domain or DNS setup required.
DOMAIN=auto

# Contact email for Let's Encrypt (expiry notices). If empty, admin@$DOMAIN
# is used. Never verified, never published.
ACME_EMAIL=

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_DB=app
# Leave empty: a random 32-char password is generated on first deploy and
# written back to this file. If you set your own, stick to alphanumerics
# (it is embedded in a connection URL).
POSTGRES_PASSWORD=

# ── Hetzner provisioning ─────────────────────────────────────────────────────
# Used by ./deploy.sh hetzner. Authentication: export HCLOUD_TOKEN=...
SERVER_NAME=vibe2prod
SERVER_TYPE=cx23
# nbg1 (Nuremberg) | fsn1 (Falkenstein) | hel1 (Helsinki) — CX servers are EU-only
SERVER_LOCATION=nbg1
SERVER_IMAGE=ubuntu-24.04

# Public SSH key uploaded to Hetzner and authorized for the 'deploy' user.
# If empty, ~/.ssh/id_ed25519.pub then ~/.ssh/id_rsa.pub are tried.
SSH_KEY_PATH=
# Name of the key object in your Hetzner project.
SSH_KEY_NAME=vibe2prod

# ── Source ───────────────────────────────────────────────────────────────────
# What the server clones and runs on first boot. Point this at your fork
# once you've replaced the demo app (see README: Bring your own app).
REPO_URL=https://github.com/westart/vibe2prod.git
GIT_REF=main
